   "id": "def:AvoidsMonotoneAP",
   "kind": "definition",
   "label": "AvoidsMonotoneAP",
   "lean": "def AvoidsMonotoneAP {ι : Type*} [LinearOrder ι] (P : ι → ℤ) (k : ℕ) : Prop := ¬ ∃ (idx : Fin k → ι) (a d : ℤ), StrictMono idx ∧ d ≠ 0 ∧ ∀ t : Fin k, P (idx t) = a + ((t : ℕ) : ℤ) * d",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:AvoidsAPmod",
   "kind": "definition",
   "label": "AvoidsAPmod",
   "lean": "def AvoidsAPmod (n k : ℕ) (σ : Fin n → ZMod n) : Prop := ¬ ∃ (idx : Fin k → Fin n) (a d : ZMod n), StrictMono idx ∧ d ≠ 0 ∧ ∀ t : Fin k, σ (idx t) = a + ((t : ℕ) : ZMod n) * d",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:AllAPDiffDvd",
   "kind": "definition",
   "label": "AllAPDiffDvd",
   "lean": "def AllAPDiffDvd {ι : Type*} [LinearOrder ι] (P : ι → ℤ) (k : ℕ) (n : ℤ) : Prop := ∀ (idx : Fin k → ι) (a d : ℤ), StrictMono idx → d ≠ 0 → (∀ t : Fin k, P (idx t) = a + ((t : ℕ) : ℤ) * d) → n ∣ d",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:kPermissible",
   "kind": "definition",
   "label": "kPermissible",
   "lean": "def kPermissible (n k : ℕ) : Prop := ∃ σ : Fin n → ZMod n, Function.Bijective σ ∧ AvoidsAPmod n k σ",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:numAvoidPerm",
   "kind": "definition",
   "label": "numAvoidPerm",
   "lean": "noncomputable def numAvoidPerm (n k : ℕ) : ℕ := Set.ncard {σ : Fin n → ZMod n | Function.Bijective σ ∧ AvoidsAPmod n k σ}",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:PermutableAvoiding",
   "kind": "definition",
   "label": "PermutableAvoiding",
   "lean": "def PermutableAvoiding (S : Set ℤ) (k : ℕ) : Prop := ∃ e : ℕ → ℤ, Function.Injective e ∧ Set.range e = S ∧ AvoidsMonotoneAP e k",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:lowerDensityPos",
   "kind": "definition",
   "label": "lowerDensityPos",
   "lean": "noncomputable def lowerDensityPos (S : Set ℤ) : ℝ := Filter.liminf (fun n : ℕ => ((S ∩ Set.Icc (1 : ℤ) (n : ℤ)).ncard : ℝ) / (n : ℝ)) Filter.atTop",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:lowerDensityInt",
   "kind": "definition",
   "label": "lowerDensityInt",
   "lean": "noncomputable def lowerDensityInt (R : Set ℤ) : ℝ := Filter.liminf (fun n : ℕ => ((R ∩ Set.Icc (-(n : ℤ)) (n : ℤ)).ncard : ℝ) / (2 * (n : ℝ))) Filter.atTop",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:upperDensityInt",
   "kind": "definition",
   "label": "upperDensityInt",
   "lean": "noncomputable def upperDensityInt (R : Set ℤ) : ℝ := Filter.limsup (fun n : ℕ => ((R ∩ Set.Icc (-(n : ℤ)) (n : ℤ)).ncard : ℝ) / (2 * (n : ℝ))) Filter.atTop",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:betaPos",
   "kind": "definition",
   "label": "betaPos",
   "lean": "noncomputable def betaPos (k : ℕ) : ℝ := sSup {x : ℝ | ∃ S : Set ℤ, S ⊆ {z : ℤ | 0 < z} ∧ PermutableAvoiding S k ∧ x = lowerDensityPos S}",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:betaInt",
   "kind": "definition",
   "label": "betaInt",
   "lean": "noncomputable def betaInt (k : ℕ) : ℝ := sSup {x : ℝ | ∃ R : Set ℤ, PermutableAvoiding R k ∧ x = lowerDensityInt R}",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:alphaInt",
   "kind": "definition",
   "label": "alphaInt",
   "lean": "noncomputable def alphaInt (k : ℕ) : ℝ := sSup {x : ℝ | ∃ R : Set ℤ, PermutableAvoiding R k ∧ x = upperDensityInt R}",
   "status": "out_of_scope"
  },
