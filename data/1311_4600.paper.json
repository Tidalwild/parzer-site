   "label": "thm_thm_manyprimes",
   "lean": "theorem thm_thm_manyprimes : ∃ C : ℝ, 0 < C ∧ ∀ (m : ℕ), 1 ≤ m → ((Filter.liminf (fun n => nthPrime (n + m) - nthPrime n) Filter.atTop : ℕ) : ℝ) ≤ C * (m : ℝ) ^ 3 * Real.exp (4 * (m : ℝ)) := by sorry",
