   "lean": "theorem thm_th_rnk : (rCoeff (2 * m) k = (if m = 1 ∧ k = 0 then (1 : ℤ) else 0) + (∑ i ∈ Finset.range (m / 2 + 1), (-1 : ℤ) ^ i * (Nat.choose (m - i) i : ℤ) * trinom (m - 2 * i) (k - 2 * i)) - (∑ i ∈ Finset.range ((m - 1) / 2 + 1), (-1 : ℤ) ^ i * (Nat.choose (m - i - 1) i : ℤ) * trinom (m - 2 * i - 1) (k - 2 * i)) + (∑ i ∈ Finset.range ((m - 2) / 2 + 1), (-1 : ℤ) ^ i * (Nat.choose (m - i - 2) i : ℤ) * trinom (m - 2 * i - 2) (k - 2 * i))) ∧ (rCoeff (2 * m + 1) k = (∑ i ∈ Finset.range (m / 2 + 1), (-1 : ℤ) ^ i * (Nat.choose (m - i) i : ℤ) * (trinom (m - 2 * i) (k - 2 * i) + trinom (m - 2 * i) (k - 2 * i - 1))) - (∑ i ∈ Finset.range ((m - 1) / 2 + 1), (-1 : ℤ) ^ i * (Nat.choose (m - i - 1) i : ℤ) * (trinom (m - 2 * i - 1) (k - 2 * i - 1) + trinom (m - 2 * i - 1) (k - 2 * i - 2)))) := by sorry",
