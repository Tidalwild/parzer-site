   "id": "def:Simplicial",
   "kind": "definition",
   "label": "Simplicial",
   "lean": "def Simplicial {W : Type} (Gr : SimpleGraph W) (v : W) : Prop := Gr.IsClique (Gr.neighborSet v)",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:IsMaximalClique",
   "kind": "definition",
   "label": "IsMaximalClique",
   "lean": "def IsMaximalClique {W : Type} (Gr : SimpleGraph W) (s : Set W) : Prop := Gr.IsClique s ∧ ∀ t : Set W, Gr.IsClique t → s ⊆ t → t ⊆ s",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:FacetEdge",
   "kind": "definition",
   "label": "FacetEdge",
   "lean": "def FacetEdge {W : Type} (Gr : SimpleGraph W) (x y : W) : Prop := Gr.Adj x y ∧ IsMaximalClique Gr ({x, y} : Set W)",
   "status": "out_of_scope"
  },
  {
   "conditionCount": 0,
   "dependsOn": [],
   "hasReceipt": false,
   "id": "def:Exposed",
   "kind": "definition",
   "label": "Exposed",
   "lean": "def Exposed {W : Type} (Gr : SimpleGraph W) (x y : W) : Prop := Gr.Adj x y ∧ (∃! s : Set W, IsMaximalClique Gr s ∧ x ∈ s ∧ y ∈ s) ∧ ¬ FacetEdge Gr x y",
   "status": "out_of_scope"
  },
