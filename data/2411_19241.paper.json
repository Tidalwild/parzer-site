   "lean": "theorem thm_thm_short_range : ∀ (b b' p κ : ℝ) (D : ℕ), 0 < b' → b' < b → 0 < p → p ≤ 1 → 0 < κ → ∃ C : ℝ, 0 < C ∧ ∀ (Ψ : Interaction), commuting Ψ → Dregular κ D → (∀ (X Y : Region) (A B : Op) (t : ℝ), rdisj X Y → suppIn A X → suppIn B Y → opNorm (ocomm (tau Ψ gamma t A) B) ≤ C * intNorm Ψ (fun r => Real.exp (-b * Real.rpow r p)) * opNorm A * opNorm B * (Min.min (rcard X) (rcard Y) : ℝ) * |t| * Real.exp (-b * Real.rpow (rdist X Y) p)) ∧ (∀ (X : Region) (A : Op) (t r : ℝ), suppIn A X → 0 ≤ r → opNorm (osub (tau Ψ gamma t A) (cexp (rball X r) (tau Ψ gamma t A))) ≤ C * intNorm Ψ (fun r => Real.exp (-b * Real.rpow r p)) * opNorm A * (rcard X : ℝ) * |t| * Real.exp (-b * Real.rpow r p)) := by sorry",
