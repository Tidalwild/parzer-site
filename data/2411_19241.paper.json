   "label": "thm_thm_finite_range",
   "lean": "theorem thm_thm_finite_range : ∀ (Ψ : Interaction) (R : ℝ), commuting Ψ → (∀ Z : Region, R < rdiam Z → intVal Ψ Z = ozero) → (∃ Cpsi : ℝ, ∀ Z : Region, opNorm (intVal Ψ Z) < Cpsi) → (∀ (X : Region) (A : Op) (t : ℝ), suppIn A X → (tau Ψ gamma t A = tau Ψ (rball X R) t A ∧ suppIn (tau Ψ gamma t A) (rball X R))) ∧ (∀ (X Y : Region) (A B : Op) (t : ℝ), suppIn A X → suppIn B Y → R < rdist X Y → opNorm (ocomm (tau Ψ gamma t A) B) = 0) := by sorry",
